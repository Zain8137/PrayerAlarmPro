#:import dp kivy.metrics.dp


<HomeScreen>:


    FloatLayout:


        canvas.before:


            Rectangle:

                source: "assets/mosque.png"

                pos: self.pos

                size: self.size



            Color:

                rgba: 0,0,0,0.55



            Rectangle:

                pos: self.pos

                size: self.size





        ScrollView:


            size_hint: 1,1

            do_scroll_x: False



            BoxLayout:


                orientation: "vertical"

                padding: dp(20)

                spacing: dp(15)

                size_hint_y: None

                height: self.minimum_height





                MDLabel:


                    text: "🕌 Prayer Alarm Pro"

                    halign: "center"

                    font_style: "H4"

                    theme_text_color: "Custom"

                    text_color: 0.8,1,0.8,1

                    size_hint_y: None

                    height: dp(60)





                MDLabel:


                    text: root.city

                    halign: "center"

                    font_style: "Subtitle1"

                    theme_text_color: "Custom"

                    text_color: 1,1,1,1

                    size_hint_y: None

                    height: dp(40)





                MDCard:


                    orientation: "horizontal"

                    padding: dp(10)

                    spacing: dp(10)

                    size_hint_y: None

                    height: dp(130)

                    radius: [15]

                    elevation: 8

                    md_bg_color: 0.85,0.65,0.13,1
                    line_color: 0.85, 0.65, 0.13, 1
                    line_width: dp(2)
                    radius: [25]




                    MDLabel:


                        text: "Next Prayer : " + root.next_prayer

                        halign: "center"

                        font_style: "H6"

                        theme_text_color: "Custom"

                        text_color: 1,1,1,1





                    MDLabel:


                        id: countdown_label

                        text: root.countdown

                        halign: "center"

                        font_size: "36sp"

                        bold: True

                        theme_text_color: "Custom"

                        text_color: 0.4,1,0.6,1




                    MDLabel:


                        text: "Today's Prayer Times"
    
                        halign: "center"
    
                        font_style: "H6"
    
                        theme_text_color: "Custom"
    
                        text_color: 1,1,1,1
    
                        size_hint_y: None
    
                        height: dp(40)





                MDCard:


                    orientation: "vertical"

                    padding: dp(15)

                    spacing: dp(8)

                    size_hint_y: None

                    height: dp(260)

                    radius: [20]

                    md_bg_color: 0,0,0,0.45





                    MDGridLayout:


                        cols: 2

                        spacing: dp(10)





                        MDLabel:


                            text: "🌅 Fajr"

                            theme_text_color: "Custom"

                            text_color: 1,1,1,1





                        MDLabel:


                            text: root.fajr

                            theme_text_color: "Custom"

                            text_color: 0.8,1,0.8,1





                        MDLabel:


                            text: "☀️ Dhuhr"

                            theme_text_color: "Custom"

                            text_color: 1,1,1,1





                        MDLabel:


                            text: root.dhuhr

                            theme_text_color: "Custom"

                            text_color: 0.8,1,0.8,1





                        MDLabel:


                            text: "🌤 Asr"

                            theme_text_color: "Custom"

                            text_color: 1,1,1,1





                        MDLabel:


                            text: root.asr

                            theme_text_color: "Custom"

                            text_color: 0.8,1,0.8,1





                        MDLabel:


                            text: "🌇 Maghrib"

                            theme_text_color: "Custom"

                            text_color: 1,1,1,1





                        MDLabel:


                            text: root.maghrib

                            theme_text_color: "Custom"

                            text_color: 0.8,1,0.8,1





                        MDLabel:


                            text: "🌙 Isha"

                            theme_text_color: "Custom"

                            text_color: 1,1,1,1





                        MDLabel:


                            text: root.isha

                            theme_text_color: "Custom"

                            text_color: 0.8,1,0.8,1




                        MDLabel:


                            text: "🔔 Alarm Settings"
        
                            halign: "center"
        
                            font_style: "H6"
        
                            theme_text_color: "Custom"
        
                            text_color: 1,1,1,1
        
                            size_hint_y: None
        
                            height: dp(40)
        




                MDCard:


                    orientation: "vertical"

                    padding: dp(15)

                    spacing: dp(8)

                    size_hint_y: None

                    height: dp(300)

                    radius: [20]

                    md_bg_color: 0,0,0,0.45





                    BoxLayout:


                        MDLabel:

                            text: "Fajr Alarm"

                            theme_text_color: "Custom"

                            text_color: 1,1,1,1



                        MDSwitch:

                            active: root.fajr_alarm

                            on_active:

                                root.fajr_alarm = self.active





                    BoxLayout:


                        MDLabel:

                            text: "Dhuhr Alarm"

                            theme_text_color: "Custom"

                            text_color: 1,1,1,1



                        MDSwitch:

                            active: root.dhuhr_alarm

                            on_active:

                                root.dhuhr_alarm = self.active





                    BoxLayout:


                        MDLabel:

                            text: "Asr Alarm"

                            theme_text_color: "Custom"

                            text_color: 1,1,1,1



                        MDSwitch:

                            active: root.asr_alarm

                            on_active:

                                root.asr_alarm = self.active





                    BoxLayout:


                        MDLabel:

                            text: "Maghrib Alarm"

                            theme_text_color: "Custom"

                            text_color: 1,1,1,1



                        MDSwitch:

                            active: root.maghrib_alarm

                            on_active:

                                root.maghrib_alarm = self.active





                    BoxLayout:


                        MDLabel:

                            text: "Isha Alarm"

                            theme_text_color: "Custom"

                            text_color: 1,1,1,1



                        MDSwitch:

                            active: root.isha_alarm

                            on_active:

                                root.isha_alarm = self.active





                MDLabel:


                    text: "🔊 Select Adhan"

                    halign: "center"

                    font_style: "H6"

                    theme_text_color: "Custom"

                    text_color: 1,1,1,1

                    size_hint_y: None

                    height: dp(40)





                Spinner:


                    id: adhan_spinner

                    text: root.selected_sound


                    values:


                        "azan1.mp3"




                    size_hint_y: None

                    height: dp(50)


                    on_text:

                        root.change_sound(self.text)





                MDRaisedButton:
                    text: "SAVE SETTINGS"
                    pos_hint:{"center_x": 0.5, "center_y": 0.5}
                    size_hint: None, None 
                    size_hint_y: None
                    height: dp(50)


                    on_release:
                        root.save_alarm_settings()        